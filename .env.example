DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@localhost:5432/stocksense

# Security
SECRET_KEY=your-super-secret-key-change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Origins
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# App Settings
PROJECT_NAME="StockSense AI"
VERSION="1.0.0"
API_STR="/api/v1"

# AI Integration (get your key from SumoPod)
SUMOPOD_API_KEY=your-sumopod-api-key-here
SUMOPOD_BASE_URL=https://ai.sumopod.com/v1
SUMOPOD_MODEL=MiniMax-M2.7-highspeed

# SMTP (opsional — untuk Laporan Terjadwal; kosongkan untuk menonaktifkan email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@pantaustok.local
